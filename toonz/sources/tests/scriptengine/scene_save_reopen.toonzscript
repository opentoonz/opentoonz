var image = new Image(new FilePath("toonz/sources/tnztools/Resources/brush.png"));
var sourceLevel = new Level();
sourceLevel.setFrame("1", image);

var levelPath = new FilePath("toonz/build/qt6-script-smoke/scene_save_reopen_level..tif");
sourceLevel.save(levelPath);

var scene = new Scene();
var loaded = scene.loadLevel("qt6_scene_saved_raster", levelPath);
scene.setCell(0, 0, loaded, "1");

var before = scene.getCell(0, 0);
print("qt-script-scene-save-before", scene.frameCount, scene.columnCount,
      scene.getLevels().length, before.level.name, before.fid);

var scenePath = new FilePath("scene_save_reopen_" + (new Date()).getTime() + ".tnz");
scene.save(scenePath);

var reopened = new Scene(scenePath);
var after = reopened.getCell(0, 0);
print("qt-script-scene-save-loaded", reopened.frameCount, reopened.columnCount,
      reopened.getLevels().length, after.level.name, after.fid);

before.level.dispose();
after.level.dispose();
reopened.dispose();
loaded.dispose();
scene.dispose();
sourceLevel.dispose();
image.dispose();

"qt-script-scene-save-reopen-result";
