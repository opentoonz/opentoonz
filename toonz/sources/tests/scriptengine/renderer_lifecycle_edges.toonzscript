function hasError(fn, needle) {
  try {
    fn();
  } catch (e) {
    return String(e.message || e).indexOf(needle) >= 0;
  }
  return false;
}

var renderer = new Renderer();
renderer.frames = [0, 2];
renderer.columns = [1];

print("qt-script-renderer-lifecycle-before", renderer.id > 0,
      renderer.toString(), renderer.frames.join(","), renderer.columns.join(","));

renderer.dispose();

var scene = new Scene();
var errors = [
  hasError(function() { renderer.toString(); }, "Invalid Renderer object"),
  hasError(function() { var value = renderer.frames; },
           "Invalid Renderer object"),
  hasError(function() { renderer.frames = [4]; },
           "Invalid Renderer object"),
  hasError(function() { var value = renderer.columns; },
           "Invalid Renderer object"),
  hasError(function() { renderer.columns = [2]; },
           "Invalid Renderer object"),
  hasError(function() { renderer.renderScene(scene); },
           "Invalid Renderer object"),
  hasError(function() { renderer.renderFrame(scene, 0); },
           "Invalid Renderer object"),
  hasError(function() { renderer.dumpCache(); }, "Invalid Renderer object")
];

print("qt-script-renderer-lifecycle-after", renderer.id, errors);

scene.dispose();

"qt-script-renderer-lifecycle-result";
