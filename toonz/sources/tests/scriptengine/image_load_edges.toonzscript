var image = new Image();
var brushPath = new FilePath("toonz/sources/tnztools/Resources/brush.png");
var karasuPath = new FilePath("toonz/sources/tnztools/Resources/karasu.png");

var firstReturn = image.load(brushPath);
print("qt-script-image-load-edges-first", firstReturn === image, image.type,
      image.width, image.height, image.toString());

var secondReturn = image.load(karasuPath);
print("qt-script-image-load-edges-second", secondReturn === image, image.type,
      image.width, image.height, image.toString());

var output = new FilePath("toonz/build/qt6-script-smoke/image_load_edges_saved.png");
var saveReturn = image.save(output);
var reloaded = new Image(output);
print("qt-script-image-load-edges-save", saveReturn === image, output.exists,
      reloaded.type, reloaded.width, reloaded.height);

reloaded.dispose();
image.dispose();

"qt-script-image-load-edges-result";
