var source = new Image(new FilePath("toonz/sources/tnztools/Resources/brush.png"));
var vectorizer = new CenterlineVectorizer();

print("qt-script-centerline-vectorizer-defaults", vectorizer.toString(),
      vectorizer.threshold, vectorizer.accuracy, vectorizer.despeckling,
      vectorizer.maxThickness, vectorizer.thicknessCalibration,
      vectorizer.preservePaintedAreas, vectorizer.addBorder, vectorizer.eir);

vectorizer.threshold = 6;
vectorizer.accuracy = 7;
vectorizer.despeckling = 3;
vectorizer.maxThickness = 160;
vectorizer.thicknessCalibration = 80;
vectorizer.preservePaintedAreas = true;
vectorizer.addBorder = true;
vectorizer.eir = false;

var vector = vectorizer.vectorize(source);
print("qt-script-centerline-vectorizer-vector", vector.type, vector.toString(),
      vector.width, vector.height, vectorizer.threshold, vectorizer.accuracy,
      vectorizer.despeckling, vectorizer.maxThickness,
      vectorizer.thicknessCalibration, vectorizer.preservePaintedAreas,
      vectorizer.addBorder, vectorizer.eir);

var output = new FilePath("toonz/build/qt6-script-smoke/centerline_vectorizer_" +
                          (new Date()).getTime() + ".pli");
vector.save(output);
var reloaded = new Image(output);
print("qt-script-centerline-vectorizer-saved", output.exists, reloaded.type,
      reloaded.toString());

var level = new Level();
level.setFrame("1", vector);
var frame = level.getFrame("1");
print("qt-script-centerline-vectorizer-level", level.type, level.frameCount,
      level.getFrameIds()[0], frame.type);

frame.dispose();
level.dispose();
reloaded.dispose();
vector.dispose();
vectorizer.dispose();
source.dispose();

"qt-script-centerline-vectorizer-result";
