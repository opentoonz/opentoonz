var source = new Image(new FilePath("toonz/sources/tnztools/Resources/brush.png"));
var vectorizer = new OutlineVectorizer();

print("qt-script-outline-vectorizer-defaults", vectorizer.toString(),
      vectorizer.accuracy, vectorizer.despeckling,
      vectorizer.preservePaintedAreas, vectorizer.transparentColor,
      vectorizer.toneThreshold);

vectorizer.accuracy = 6;
vectorizer.despeckling = 2;
vectorizer.preservePaintedAreas = true;
vectorizer.cornerAdherence = 25;
vectorizer.cornerAngle = 30;
vectorizer.cornerCurveRadius = 15;
vectorizer.maxColors = 8;
vectorizer.transparentColor = "#ff00ff";
vectorizer.toneThreshold = 96;

var vector = vectorizer.vectorize(source);
print("qt-script-outline-vectorizer-vector", vector.type, vector.toString(),
      vector.width, vector.height, vectorizer.accuracy, vectorizer.maxColors,
      vectorizer.transparentColor, vectorizer.toneThreshold);

var output = new FilePath("toonz/build/qt6-script-smoke/outline_vectorizer_" +
                          (new Date()).getTime() + ".pli");
vector.save(output);
var reloaded = new Image(output);
print("qt-script-outline-vectorizer-saved", output.exists, reloaded.type,
      reloaded.toString());

var level = new Level();
level.setFrame("1", vector);
var frame = level.getFrame("1");
print("qt-script-outline-vectorizer-level", level.type, level.frameCount,
      level.getFrameIds()[0], frame.type);

frame.dispose();
level.dispose();
reloaded.dispose();
vector.dispose();
vectorizer.dispose();
source.dispose();

"qt-script-outline-vectorizer-result";
