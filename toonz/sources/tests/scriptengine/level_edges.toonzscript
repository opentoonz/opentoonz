function hasError(fn, needle) {
  try {
    fn();
  } catch (e) {
    return String(e.message || e).indexOf(needle) >= 0;
  }
  return false;
}

var image = new Image(new FilePath("toonz/sources/tnztools/Resources/brush.png"));
var empty = new Level();

var emptyGetFrameError = hasError(function() {
  empty.getFrame("1");
}, "An empty level has no frames");
var emptyGetFrameByIndexError = hasError(function() {
  empty.getFrameByIndex(0);
}, "An empty level has no frames");
var emptySaveError = hasError(function() {
  empty.save(new FilePath("toonz/build/qt6-script-smoke/level_edges_empty..tif"));
}, "Can't save an empty level");
var emptyNameNoError = !hasError(function() {
  empty.name = "ignored";
});
var emptyNameUnchanged = empty.name === "";
var emptyPathUndefined = empty.path === undefined;

print("qt-script-level-edges-empty", empty.type, empty.frameCount,
      emptyGetFrameError, emptyGetFrameByIndexError, emptySaveError,
      emptyNameNoError, emptyNameUnchanged, emptyPathUndefined);

var raster = new Level();
raster.setFrame("1", image);

var missingFrame = raster.getFrame("99") === undefined;
var negativeIndexError = hasError(function() {
  raster.getFrameByIndex(-1);
}, "out of range");
var highIndexError = hasError(function() {
  raster.getFrameByIndex(1);
}, "out of range");
var stringIndexError = hasError(function() {
  raster.getFrameByIndex("0");
}, "must be a number");
var fractionalIndexError = hasError(function() {
  raster.getFrameByIndex(0.5);
}, "must be a number");

print("qt-script-level-edges-frame-access", raster.type, raster.frameCount,
      missingFrame, negativeIndexError, highIndexError, stringIndexError,
      fractionalIndexError);

var toonzBuilder = new ImageBuilder(9, 7, "ToonzRaster");
var toonzImage = toonzBuilder.image;

var badConstructorArityError = hasError(function() {
  new Level(new FilePath("missing..tif"), 0);
}, "Level constructor expected zero or one path argument");
var badGetFrameIdsArityError = hasError(function() {
  raster.getFrameIds(0);
}, "Level.getFrameIds expected no arguments");
var badGetFrameMissingArityError = hasError(function() {
  raster.getFrame();
}, "Level.getFrame expected one frame argument");
var badGetFrameExtraArityError = hasError(function() {
  raster.getFrame("1", 0);
}, "Level.getFrame expected one frame argument");
var badGetFrameByIndexMissingArityError = hasError(function() {
  raster.getFrameByIndex();
}, "Level.getFrameByIndex expected one index argument");
var badGetFrameByIndexExtraArityError = hasError(function() {
  raster.getFrameByIndex(0, 1);
}, "Level.getFrameByIndex expected one index argument");
var badSetFrameMissingArityError = hasError(function() {
  raster.setFrame("2");
}, "Level.setFrame expected frame and image arguments");
var badSetFrameExtraArityError = hasError(function() {
  raster.setFrame("2", image, 0);
}, "Level.setFrame expected frame and image arguments");
var badLoadMissingArityError = hasError(function() {
  raster.load();
}, "Level.load expected one path argument");
var badLoadExtraArityError = hasError(function() {
  raster.load(new FilePath("missing..tif"), 0);
}, "Level.load expected one path argument");
var badSaveMissingArityError = hasError(function() {
  raster.save();
}, "Level.save expected one path argument");
var badSaveExtraArityError = hasError(function() {
  raster.save(new FilePath("missing..tif"), 0);
}, "Level.save expected one path argument");
var badSetFrameIdError = hasError(function() {
  raster.setFrame("bad", image);
}, "does not look like a FrameId");
var badSetFrameImageError = hasError(function() {
  raster.setFrame("2", 42);
}, "second argument (42) is not an image");
var badSetFrameIdBeforeImageError = hasError(function() {
  raster.setFrame("bad", 42);
}, "does not look like a FrameId");
var typeMismatchError = hasError(function() {
  raster.setFrame("2", toonzImage);
}, "cannot insert a ToonzRaster image to a Raster level");
var incompatibleSaveError = hasError(function() {
  raster.save(new FilePath("toonz/build/qt6-script-smoke/level_edges_raster.pli"));
}, "Can't save a Raster level to this file type");
var missingLoadError = hasError(function() {
  raster.load(new FilePath("toonz/build/qt6-script-smoke/level_edges_missing..tif"));
}, "doesn't exist");

print("qt-script-level-edges-errors", badSetFrameIdError,
      badSetFrameImageError, badSetFrameIdBeforeImageError, typeMismatchError,
      incompatibleSaveError, missingLoadError);
print("qt-script-level-edges-arity", badConstructorArityError,
      badGetFrameIdsArityError, badGetFrameMissingArityError,
      badGetFrameExtraArityError, badGetFrameByIndexMissingArityError,
      badGetFrameByIndexExtraArityError, badSetFrameMissingArityError,
      badSetFrameExtraArityError, badLoadMissingArityError,
      badLoadExtraArityError, badSaveMissingArityError,
      badSaveExtraArityError);

toonzImage.dispose();
toonzBuilder.dispose();
raster.dispose();
empty.dispose();
image.dispose();

"qt-script-level-edges-result";
