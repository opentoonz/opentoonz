function hasError(fn, needle) {
  try {
    fn();
  } catch (e) {
    return String(e.message || e).indexOf(needle) >= 0;
  }
  return false;
}

var image = new Image(new FilePath("toonz/sources/tnztools/Resources/brush.png"));
var empty = new Level();

var emptyGetFrameError = hasError(function() {
  empty.getFrame("1");
}, "An empty level has no frames");
var emptyGetFrameByIndexError = hasError(function() {
  empty.getFrameByIndex(0);
}, "An empty level has no frames");
var emptySaveError = hasError(function() {
  empty.save(new FilePath("toonz/build/qt6-script-smoke/level_edges_empty..tif"));
}, "Can't save an empty level");
var emptyNameNoError = !hasError(function() {
  empty.name = "ignored";
});
var emptyNameUnchanged = empty.name === "";
var emptyPathUndefined = empty.path === undefined;

print("qt-script-level-edges-empty", empty.type, empty.frameCount,
      emptyGetFrameError, emptyGetFrameByIndexError, emptySaveError,
      emptyNameNoError, emptyNameUnchanged, emptyPathUndefined);

var raster = new Level();
raster.setFrame("1", image);

var missingFrame = raster.getFrame("99") === undefined;
var negativeIndexError = hasError(function() {
  raster.getFrameByIndex(-1);
}, "out of range");
var highIndexError = hasError(function() {
  raster.getFrameByIndex(1);
}, "out of range");
var stringIndexError = hasError(function() {
  raster.getFrameByIndex("0");
}, "must be a number");

print("qt-script-level-edges-frame-access", raster.type, raster.frameCount,
      missingFrame, negativeIndexError, highIndexError, stringIndexError);

var toonzBuilder = new ImageBuilder(9, 7, "ToonzRaster");
var toonzImage = toonzBuilder.image;

var badSetFrameIdError = hasError(function() {
  raster.setFrame("bad", image);
}, "does not look like a FrameId");
var typeMismatchError = hasError(function() {
  raster.setFrame("2", toonzImage);
}, "cannot insert a ToonzRaster image to a Raster level");
var incompatibleSaveError = hasError(function() {
  raster.save(new FilePath("toonz/build/qt6-script-smoke/level_edges_raster.pli"));
}, "Can't save a Raster level to this file type");
var missingLoadError = hasError(function() {
  raster.load(new FilePath("toonz/build/qt6-script-smoke/level_edges_missing..tif"));
}, "doesn't exist");

print("qt-script-level-edges-errors", badSetFrameIdError, typeMismatchError,
      incompatibleSaveError, missingLoadError);

toonzImage.dispose();
toonzBuilder.dispose();
raster.dispose();
empty.dispose();
image.dispose();

"qt-script-level-edges-result";
