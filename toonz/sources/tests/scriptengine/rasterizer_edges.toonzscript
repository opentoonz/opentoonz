function hasError(fn, needle) {
  try {
    fn();
  } catch (e) {
    return String(e).indexOf(needle) >= 0;
  }
  return false;
}

var source = new Image(new FilePath("toonz/sources/tnztools/Resources/brush.png"));
var vector = new OutlineVectorizer().vectorize(source);
var toonz = ToonzRasterConverter.convert(source);
var scene = new Scene();
var rasterLevel = scene.newLevel("Raster", "qt6_rasterizer_edges_raster");
var emptyLevel = new Level();
var rasterizer = new Rasterizer();

var badFullColorGeometryError = hasError(function() {
  rasterizer.xres = 0;
  rasterizer.rasterize(vector);
}, "Bad Rasterizer resolution or dpi");

rasterizer.colorMapped = true;
rasterizer.xres = 720;
var rasterized = rasterizer.rasterize(vector);
print("qt-script-rasterizer-edges-success", badFullColorGeometryError,
      rasterized.type, rasterized.width, rasterized.height);
var rasterizedAgain = rasterizer.rasterize(vector);
var rasterizedWrapperIdsDiffer = rasterized.id !== rasterizedAgain.id;
rasterized.dispose();
var rasterizedWrapperStillValid = rasterizedAgain.type === "ToonzRaster" &&
    rasterizedAgain.width === 720 && rasterizedAgain.height === 576;
print("qt-script-rasterizer-edges-wrappers", rasterizedWrapperIdsDiffer,
      rasterizedWrapperStillValid);

var errors = [
  hasError(function() { new Rasterizer(0); },
           "Rasterizer constructor expected no arguments"),
  hasError(function() { rasterizer.xres = 12.5; },
           "Rasterizer.xres must be an integer"),
  hasError(function() { rasterizer.dpi = Infinity; },
           "Rasterizer.dpi must be a finite number"),
  hasError(function() { rasterizer.rasterize(); },
           "Rasterizer.rasterize expected one argument"),
  hasError(function() { rasterizer.rasterize(vector, vector); },
           "Rasterizer.rasterize expected one argument"),
  hasError(function() { rasterizer.rasterize(42); },
           "Argument must be a vector level or image"),
  hasError(function() { rasterizer.rasterize(source); },
           "Expected a vector image"),
  hasError(function() { rasterizer.rasterize(toonz); },
           "Expected a vector image"),
  hasError(function() { rasterizer.rasterize(rasterLevel); },
           "Expected a vector level"),
  hasError(function() { rasterizer.rasterize(emptyLevel); },
           "Expected a vector level")
];
print("qt-script-rasterizer-edges-errors", errors);

rasterizedAgain.dispose();
rasterizer.dispose();
emptyLevel.dispose();
rasterLevel.dispose();
scene.dispose();
toonz.dispose();
vector.dispose();
source.dispose();

"qt-script-rasterizer-edges-result";
