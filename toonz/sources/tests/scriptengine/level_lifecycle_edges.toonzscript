function hasError(fn, needle) {
  try {
    fn();
  } catch (e) {
    return String(e.message || e).indexOf(needle) >= 0;
  }
  return false;
}

var image = new Image(new FilePath("toonz/sources/tnztools/Resources/brush.png"));
var level = new Level();
level.setFrame("1", image);

print("qt-script-level-lifecycle-before", level.id > 0, level.type,
      level.frameCount, level.name, level.path === undefined,
      level.toString());

level.dispose();

var errors = [
  hasError(function() { level.toString(); }, "Invalid Level object"),
  hasError(function() { var value = level.type; }, "Invalid Level object"),
  hasError(function() { var value = level.frameCount; }, "Invalid Level object"),
  hasError(function() { var value = level.name; }, "Invalid Level object"),
  hasError(function() { level.name = "disposed"; }, "Invalid Level object"),
  hasError(function() { var value = level.path; }, "Invalid Level object"),
  hasError(function() { level.path = "toonz/build/qt6-script-smoke/disposed..tif"; },
           "Invalid Level object"),
  hasError(function() { level.getFrameIds(); }, "Invalid Level object"),
  hasError(function() { level.getFrame("1"); }, "Invalid Level object"),
  hasError(function() { level.getFrameByIndex(0); }, "Invalid Level object"),
  hasError(function() { level.setFrame("2", image); }, "Invalid Level object"),
  hasError(function() { level.load(new FilePath("toonz/sources/tnztools/Resources/brush.png")); },
           "Invalid Level object"),
  hasError(function() { level.save(new FilePath("toonz/build/qt6-script-smoke/level_lifecycle_disposed..tif")); },
           "Invalid Level object")
];

print("qt-script-level-lifecycle-after", level.id, errors);

image.dispose();

"qt-script-level-lifecycle-result";
