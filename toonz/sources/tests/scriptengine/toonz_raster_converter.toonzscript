var source = new Image(new FilePath("toonz/sources/tnztools/Resources/brush.png"));
var converter = new ToonzRasterConverter();
print("qt-script-toonz-raster-converter-object", converter.toString(),
      converter.foo(7), converter.flatSource);

converter.flatSource = true;
var converted = ToonzRasterConverter.convert(source);
print("qt-script-toonz-raster-converter-image", converted.type,
      converted.width, converted.height, converted.toString(),
      converter.flatSource);

var output = new FilePath("toonz/build/qt6-script-smoke/toonz_raster_converter_" +
                          (new Date()).getTime() + "..tlv");
converted.save(output);
var reloaded = new Image(output);
print("qt-script-toonz-raster-converter-saved", output.exists, reloaded.type,
      reloaded.width, reloaded.height);

reloaded.dispose();
converted.dispose();
source.dispose();

"qt-script-toonz-raster-converter-result";
